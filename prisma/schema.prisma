generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CUSTOMER
}

enum ProductUnit {
  KG
  LITRE
  ML
  METER
  PACK
  PIECE
  BOTTLE
  COMBO_KIT
}

enum OrderStatus {
  PENDING_WHATSAPP
  CONFIRMED
  PAYMENT_PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model User {
  id             String     @id @default(cuid())
  name           String
  email          String     @unique
  password       String
  role           Role       @default(CUSTOMER)
  whatsappNumber String?
  orders         Order[]
  cartItems      CartItem[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Category {
  id               String     @id @default(cuid())
  name             String
  slug             String     @unique
  image            String?
  // Self-relation for subcategory support
  parentId         String?
  parent           Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children         Category[] @relation("CategoryChildren")
  // Homepage display fields
  bannerImage      String?
  homeTileImage    String?
  featuredOnHome   Boolean    @default(false)
  homeDisplayOrder Int        @default(0)
  description      String?
  products         Product[]
  createdAt        DateTime   @default(now())
}

model Product {
  id               String      @id @default(cuid())
  name             String
  slug             String      @unique
  description      String
  price            Decimal     @db.Decimal(10, 2)
  // Compare-at / "was" price shown crossed-out next to the selling price
  compareAtPrice   Decimal?    @db.Decimal(10, 2)
  showComparePrice Boolean     @default(false)
  stock            Int
  unit             ProductUnit
  images           String[]
  categoryId       String
  category         Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  cartItems        CartItem[]
  createdAt        DateTime    @default(now())
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String?
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@unique([sessionId, productId])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String?
  user            User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  customerName    String
  whatsappNumber  String
  items           Json
  totalAmount     Decimal     @db.Decimal(10, 2)
  status          OrderStatus @default(PENDING_WHATSAPP)
  shippingAddress String?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

